{"nl": "画一个等边三角形 ABC，边长为 4", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}], "constraints": [{"type": "equilateral", "polygon": "tri"}, {"type": "length", "segment": "AB", "value": 4}], "annotations": [{"target": "AB", "kind": "length"}], "labels": {"A": "A", "B": "B", "C": "C"}}}
{"nl": "画一个内切圆半径为 3 的等腰三角形", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}, {"id": "inc", "kind": "circle", "definition": {"type": "incircle", "of": "tri"}}], "constraints": [{"type": "isoceles", "polygon": "tri", "apex": "A"}, {"type": "radius", "circle": "inc", "value": 3}, {"type": "angle", "a": "A", "b": "B", "c": "C", "value": 70}], "annotations": [{"target": "inc", "kind": "radius"}], "labels": {"A": "A", "B": "B", "C": "C"}}}
{"nl": "画直角三角形 ABC，C 为直角顶点，BC=3，CA=4", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}], "constraints": [{"type": "right_triangle", "polygon": "tri", "right_at": "C"}, {"type": "length", "segment": "BC", "value": 3}, {"type": "length", "segment": "CA", "value": 4}], "annotations": [{"target": "BC", "kind": "length"}, {"target": "CA", "kind": "length"}], "labels": {"A": "A", "B": "B", "C": "C"}}}
{"nl": "画一个边长为 5 的正方形 ABCD", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "D", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CD", "kind": "segment", "a": "C", "b": "D"}, {"id": "DA", "kind": "segment", "a": "D", "b": "A"}, {"id": "sq", "kind": "polygon", "vertices": ["A", "B", "C", "D"]}], "constraints": [{"type": "equal_length", "segments": ["AB", "BC", "CD", "DA"]}, {"type": "perpendicular", "a": "AB", "b": "BC"}, {"type": "perpendicular", "a": "BC", "b": "CD"}, {"type": "length", "segment": "AB", "value": 5}], "labels": {"A": "A", "B": "B", "C": "C", "D": "D"}}}
{"nl": "画圆 O，半径为 5，A、B 两点在圆上，AOB 角为 90 度", "dsl": {"version": "0.1", "objects": [{"id": "O", "kind": "point"}, {"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "OA", "kind": "segment", "a": "O", "b": "A"}, {"id": "OB", "kind": "segment", "a": "O", "b": "B"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "circ", "kind": "circle", "definition": {"type": "center_radius", "center": "O", "radius": 5}}], "constraints": [{"type": "on_circle", "point": "A", "circle": "circ"}, {"type": "on_circle", "point": "B", "circle": "circ"}, {"type": "angle", "a": "A", "b": "O", "c": "B", "value": 90}], "annotations": [{"target": "AB", "kind": "length"}], "labels": {"O": "O", "A": "A", "B": "B"}}}
{"nl": "画一个三角形 ABC 和它的外接圆", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}, {"id": "circ", "kind": "circle", "definition": {"type": "circumcircle", "of": "tri"}}], "constraints": [{"type": "length", "segment": "AB", "value": 5}, {"type": "length", "segment": "BC", "value": 6}, {"type": "length", "segment": "CA", "value": 7}], "labels": {"A": "A", "B": "B", "C": "C"}}}
{"nl": "画一个菱形 ABCD，边长 4，∠A = 60°", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "D", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CD", "kind": "segment", "a": "C", "b": "D"}, {"id": "DA", "kind": "segment", "a": "D", "b": "A"}, {"id": "rh", "kind": "polygon", "vertices": ["A", "B", "C", "D"]}], "constraints": [{"type": "equal_length", "segments": ["AB", "BC", "CD", "DA"]}, {"type": "length", "segment": "AB", "value": 4}, {"type": "angle", "a": "D", "b": "A", "c": "B", "value": 60}], "labels": {"A": "A", "B": "B", "C": "C", "D": "D"}}}
{"nl": "画一个矩形 ABCD，长 6 宽 4", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "D", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CD", "kind": "segment", "a": "C", "b": "D"}, {"id": "DA", "kind": "segment", "a": "D", "b": "A"}, {"id": "rect", "kind": "polygon", "vertices": ["A", "B", "C", "D"]}], "constraints": [{"type": "perpendicular", "a": "AB", "b": "BC"}, {"type": "perpendicular", "a": "BC", "b": "CD"}, {"type": "perpendicular", "a": "CD", "b": "DA"}, {"type": "length", "segment": "AB", "value": 6}, {"type": "length", "segment": "BC", "value": 4}], "labels": {"A": "A", "B": "B", "C": "C", "D": "D"}}}
{"nl": "画一个等腰直角三角形 ABC，C 为直角顶点，腰长 4", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}], "constraints": [{"type": "right_triangle", "polygon": "tri", "right_at": "C"}, {"type": "equal_length", "segments": ["CA", "BC"]}, {"type": "length", "segment": "CA", "value": 4}], "labels": {"A": "A", "B": "B", "C": "C"}}}
{"nl": "圆 O 半径 5，AB 为直径，C 在圆上", "dsl": {"version": "0.1", "objects": [{"id": "O", "kind": "point"}, {"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "circ", "kind": "circle", "definition": {"type": "center_radius", "center": "O", "radius": 5}}], "constraints": [{"type": "on_circle", "point": "A", "circle": "circ"}, {"type": "on_circle", "point": "B", "circle": "circ"}, {"type": "on_circle", "point": "C", "circle": "circ"}, {"type": "collinear", "points": ["A", "O", "B"]}], "labels": {"O": "O", "A": "A", "B": "B", "C": "C"}}}
{"nl": "画一个三角形 ABC，M 是 BC 的中点，连接 AM", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "M", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "AM", "kind": "segment", "a": "A", "b": "M"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}], "constraints": [{"type": "length", "segment": "AB", "value": 5}, {"type": "length", "segment": "BC", "value": 6}, {"type": "length", "segment": "CA", "value": 7}, {"type": "midpoint", "m": "M", "a": "B", "b": "C"}], "labels": {"A": "A", "B": "B", "C": "C", "M": "M"}}}
{"nl": "画一个平行四边形 ABCD，AB=6 BC=4 ∠A=70 度", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "D", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CD", "kind": "segment", "a": "C", "b": "D"}, {"id": "DA", "kind": "segment", "a": "D", "b": "A"}, {"id": "p", "kind": "polygon", "vertices": ["A", "B", "C", "D"]}], "constraints": [{"type": "parallelogram", "polygon": "p"}, {"type": "length", "segment": "AB", "value": 6}, {"type": "length", "segment": "BC", "value": 4}, {"type": "angle", "a": "D", "b": "A", "c": "B", "value": 70}], "labels": {"A": "A", "B": "B", "C": "C", "D": "D"}}}
{"nl": "画一个平面直角坐标系", "dsl": {"version": "0.1", "objects": [{"id": "O", "kind": "point"}, {"id": "ax", "kind": "axis", "origin": "O", "x_range": [-5, 5], "y_range": [-5, 5], "tick_step": 1, "show_grid": true}], "constraints": [], "labels": {"O": "O"}}}
{"nl": "画一个坐标系，x 轴从 -10 到 10，y 轴从 -6 到 6", "dsl": {"version": "0.1", "objects": [{"id": "O", "kind": "point"}, {"id": "ax", "kind": "axis", "origin": "O", "x_range": [-10, 10], "y_range": [-6, 6], "tick_step": 2, "show_grid": true}], "constraints": [], "labels": {"O": "O"}}}
{"nl": "画直角三角形 ABC，C 为直角顶点，C 位于 AB 上方，BC=3，CA=4", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "P0", "kind": "point", "hint": [0, 5]}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}], "constraints": [{"type": "right_triangle", "polygon": "tri", "right_at": "C"}, {"type": "length", "segment": "BC", "value": 3}, {"type": "length", "segment": "CA", "value": 4}, {"type": "same_side", "line": "AB", "point": "C", "ref": "P0"}], "annotations": [{"target": "BC", "kind": "length"}, {"target": "CA", "kind": "length"}], "labels": {"A": "A", "B": "B", "C": "C"}}}
{"nl": "画三角形 ABC，AB=4，BC=3，∠B=60°；作三角形 ABC 关于点 B 的中心对称图形 A'B'C'", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}, {"id": "tri2", "kind": "transformed_polygon", "source": "tri", "transform": {"type": "central_symmetry", "center": "B"}, "vertex_suffix": "p"}], "constraints": [{"type": "length", "segment": "AB", "value": 4}, {"type": "length", "segment": "BC", "value": 3}, {"type": "angle", "a": "A", "b": "B", "c": "C", "value": 60}], "labels": {"A": "A", "B": "B", "C": "C"}}}
{"nl": "画直角三角形 ABC，∠ABC=90°，AB=1，BC=2；将线段 AC 绕点 A 旋转 90° 得到线段 AD", "dsl": {"version": "0.1", "objects": [{"id": "A", "kind": "point"}, {"id": "B", "kind": "point"}, {"id": "C", "kind": "point"}, {"id": "AB", "kind": "segment", "a": "A", "b": "B"}, {"id": "BC", "kind": "segment", "a": "B", "b": "C"}, {"id": "CA", "kind": "segment", "a": "C", "b": "A"}, {"id": "tri", "kind": "polygon", "vertices": ["A", "B", "C"]}, {"id": "D", "kind": "transformed_point", "source": "C", "transform": {"type": "rotation", "center": "A", "angle": 90}}, {"id": "AD", "kind": "segment", "a": "A", "b": "D"}], "constraints": [{"type": "right_triangle", "polygon": "tri", "right_at": "B"}, {"type": "length", "segment": "AB", "value": 1}, {"type": "length", "segment": "BC", "value": 2}], "labels": {"A": "A", "B": "B", "C": "C"}}}
