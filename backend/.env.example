# ============================================================
# 话图 T2G 后端配置
# 复制本文件为 .env 并填入你的 Key（.env 已加入 .gitignore）
# ============================================================

# ----- 默认 Provider（前端首次打开预选；后端找不到对应 Key 时返回 disabled） -----
DEFAULT_PROVIDER=zhipu

# ----- 智谱 BigModel -----
# 申请：https://open.bigmodel.cn/
ZHIPU_API_KEY=
# 可选：覆盖默认 endpoint / 模型
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_MODEL=glm-4.5            # GLM-5.2 上线后改成 glm-5.2

# ----- 火山引擎方舟 Ark -----
# 在火山方舟控制台创建"接入点（Endpoint）"，承载任意你已开通的模型
# （包括但不限于 GLM-5.2 / DeepSeek / 豆包），然后把 Endpoint ID 填到下面
# 申请：https://www.volcengine.com/product/ark
VOLCENGINE_API_KEY=
VOLCENGINE_ENDPOINT_ID=           # 形如 ep-2024xxxx-xxxxx
# 可选：覆盖默认区域 endpoint
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ----- DeepSeek -----
# 申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# 可选
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat   # V4 Pro 上线后按官方文档改

# ----- MiniMax -----
# 申请：https://platform.minimaxi.com/
MINIMAX_API_KEY=
# 可选
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M3

# ============================================================
# 场景示例
# ============================================================
# 场景 1：通过智谱 BigModel 用 GLM-5.2
#   ZHIPU_API_KEY=sk-xxxxx
#   ZHIPU_MODEL=glm-5.2
#   DEFAULT_PROVIDER=zhipu
#
# 场景 2：通过火山方舟用 GLM-5.2（火山转售）
#   VOLCENGINE_API_KEY=xxxxx
#   VOLCENGINE_ENDPOINT_ID=ep-xxxx-glm52
#   DEFAULT_PROVIDER=volcengine
#
# 场景 3：同时配多家，老师在 UI 自由切换 — 把全部 Key 都填上即可
# ============================================================

# ----- 日志 -----
LOG_LEVEL=INFO
# 以下为本地开发用；Docker 部署时不要保留这两行（让 Dockerfile 的 ENV 生效）
# DATABASE_URL=sqlite+aiosqlite:///./data/talk2graph.db
# LOG_DIR=./logs
